<html lang="en">
<body style="font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8f9fa; margin: 0; padding: 0;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color: #f8f9fa; padding: 20px 0;">
    <tr>
      <td align="center">
        <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="max-width: 600px; width: 100%;">
          <tr>
            <td>
              {{> email-header}}
            </td>
          </tr>
          <tr>
            <td style="background-color: #ffffff; border-radius: 8px; padding: 40px; border: 1px solid #e9ecef;">
              <h1 style="color: #1F3A5F; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-size: 24px; font-weight: 600; margin: 0 0 20px 0;">Your Password Has Been Changed</h1>
              <p style="color: #495057; font-size: 16px; line-height: 1.6; margin: 0 0 16px 0;">Hi {{userName}}, your password was successfully changed on {{timestamp}}.</p>
              <p style="color: #6c757d; font-size: 14px; line-height: 1.6; margin: 0 0 24px 0;">If you did not make this change, please contact support immediately.</p>
              <table role="presentation" cellpadding="0" cellspacing="0" border="0">
                <tr>
                  <td>
                    <a href="{{supportLink}}" target="_blank" style="background-color: #1F3A5F; color: #ffffff; padding: 12px 28px; border-radius: 6px; text-decoration: none; display: inline-block; font-weight: 600; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; font-size: 16px;">Contact Support</a>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td>
              {{> transactional-footer}}
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
