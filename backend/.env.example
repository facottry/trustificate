# ── App ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
CORS_ORIGIN=*
FRONTEND_URL=https://trustificate.clicktory.in

# ── Portless (local dev) ────────────────────────────────
# Proxy: portless proxy start -p 80 (run once from Admin terminal)
# Backend: http://api.trustificate.localhost
# Frontend: http://trustificate.localhost
# Install: npm install -g portless
# Start:   cd backend && npm run dev
#           cd frontend && npm run dev

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=replace_this_with_a_strong_32+_char_secret
JWT_EXPIRES_IN=7d

# ── MongoDB ──────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/trustificate

# ── Cloudflare R2 (for storing generated PDFs and uploads) ─────────────────
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_BUCKET_NAME=your_bucket_name
# Optional: if you have a custom public domain for file access
R2_PUBLIC_BASE_URL=https://files.yourdomain.com

# ── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key